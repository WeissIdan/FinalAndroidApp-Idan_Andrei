<?xml version="1.0" encoding="utf-8"?>
<!-- Thumb color for switchUnits in fragment_settings.xml: blue when ON, white when OFF,
     so toggling it visibly changes color instead of just sliding position. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true" android:color="@color/accent_blue" />
    <item android:color="@color/white" />
</selector>
