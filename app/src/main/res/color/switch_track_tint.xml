<?xml version="1.0" encoding="utf-8"?>
<!-- Track color for switchUnits, paired with switch_thumb_tint.xml: half-opacity blue
     when ON, half-opacity gray when OFF. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true" android:color="@color/accent_blue" android:alpha="0.5" />
    <item android:color="@color/text_secondary" android:alpha="0.5" />
</selector>
